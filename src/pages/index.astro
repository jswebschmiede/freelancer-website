---
export const prerender = true;

import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Section from '@components/Ui/Section.astro';
import Card from '@components/Ui/Card.astro';
import PageLayout from '@layouts/PageLayout.astro';
import Button from '@components/Ui/Button.astro';
import ContactItem from '@components/Ui/ContactItem.astro';
import Project from '@components/Project/Project.astro';
import Faq from '@components/Faq.astro';
import Hero from '@components/Hero.astro';
import MagicCard from '@components/Ui/MagicCard.astro';
import EyebrowHeading from '@components/Ui/EyebrowHeading.astro';
import { painPoints, trustItems, services, steps, techCategories } from '../agentur';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const meta = {
  title: 'Freelance Webentwicklung für Agenturen und Unternehmen',
  description:
    'Freelance Webentwicklung für Agenturen und Unternehmen. Individuelle WordPress-Themes, Joomla-Templates und performante Websites mit Astro. Zuverlässig, pixelgenau, technisch einwandfrei.',
};
const formStatus = Astro.url.searchParams.get('status');
---

<PageLayout {meta} bodyClass="home">
  <Hero slot="hero" />

  <Section
    id="herausforderung"
    className="bg-[radial-gradient(circle_at_30%_50%,var(--color-primary)_-200%,transparent_25%)]"
  >
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:alert-circle-outline" text="Die Herausforderung" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Kennen Sie <span class="text-primary">das?</span>
      </h2>
    </div>

    <div
      class="reveal-fx--translate-up reveal-fx relative z-10 mx-auto mt-16 grid max-w-7xl grid-cols-1 gap-8 px-4 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        painPoints.map(item => (
          <MagicCard
            title={item.title}
            icon={item.icon}
            className="hover:translate-y-0 border-error/20 hover:border-error/40"
          >
            <p set:html={item.text} />
          </MagicCard>
        ))
      }
    </div>

    <div class="reveal-fx--translate-up reveal-fx mx-auto mt-16 max-w-3xl px-4 text-center">
      <p class="text-lg text-base-content/75">
        <strong class="text-primary">Die gute Nachricht:</strong> Sie müssen das nicht alleine lösen.
        Konzentrieren Sie sich auf Kreation und Kundenbetreuung – ich übernehme die technische Umsetzung.
      </p>
    </div>
  </Section>

  <Section
    id="leistungen"
    className="bg-[radial-gradient(circle_at_30%_50%,var(--color-primary)_-200%,transparent_25%),radial-gradient(circle_at_70%_60%,var(--color-accent)_-200%,transparent_20%)]"
  >
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:cog-outline" text="Leistungen für Agenturen" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Ihr verlängerter <span class="text-primary">Entwickler-Arm</span>
      </h2>
      <p class="mx-auto max-w-4xl">
        Ob als langfristige Unterstützung oder Feuerwehr bei Engpässen: Ich liefere sauberen Code,
        halte Deadlines ein und integriere mich nahtlos in Ihre Prozesse.
      </p>
    </div>

    <div
      class="reveal-fx--translate-up cards-wrap reveal-fx relative z-10 mx-auto mb-6 mt-24 grid max-w-7xl grid-cols-1 gap-8 px-4 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        (services ?? []).map(item => (
          <MagicCard title={item.title} icon={item.icon}>
            <p set:html={item.text} />
          </MagicCard>
        ))
      }
    </div>
  </Section>

  <Section id="prozess">
    <div
      class="reveal-fx--translate-up reveal-fx relative z-10 mx-auto grid max-w-7xl grid-cols-1 gap-20 px-4 lg:grid-cols-12"
    >
      <div class="lg:col-span-5">
        <div class="prose sticky top-24 lg:prose-lg prose-h2:mt-0">
          <EyebrowHeading icon="mdi:workflow-outline" text="Der Prozess" />
          <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
            So läuft die <span class="text-primary">Zusammenarbeit</span> ab
          </h2>
          <p>
            Vom Briefing bis zum Go-Live – vier Schritte, die Sie jederzeit nachvollziehen können.
            Keine Überraschungen bei Aufwand, Timing oder Kosten.
          </p>
          <div
            class="mt-9 flex flex-col items-start justify-start gap-8 sm:flex-row sm:items-center"
          >
            <Button href="#kontakt" variant="outline">
              <Icon name="mdi:message-outline" class="w-5 h-5" /> Anfrage stellen
            </Button>
            <Button href="#fragen" className="group">
              Fragen? <Icon
                name="mdi:arrow-right"
                class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-200 will-change-transform"
              />
            </Button>
          </div>
        </div>
      </div>

      <div class="space-y-24 lg:col-span-7">
        {
          (steps ?? []).map(step => (
            <MagicCard className="mx-auto transition-shadow hover:translate-y-0 lg:max-w-md">
              <h3 class="text-2xl font-bold group-hover:text-primary">{step.title}</h3>
              <p>{step.text}</p>
            </MagicCard>
          ))
        }
      </div>
    </div>
  </Section>

  <Section
    id="vertrauen"
    className="bg-[radial-gradient(circle_at_30%_50%,var(--color-primary)_-200%,transparent_25%),radial-gradient(circle_at_70%_60%,var(--color-accent)_-200%,transparent_20%)]"
  >
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:shield-check-outline" text="Warum ich?" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Was mich von anderen <br /><span class="text-primary">Freelancern</span> unterscheidet
      </h2>
    </div>

    <div
      class="reveal-fx--translate-up reveal-fx relative z-10 mx-auto mt-16 grid max-w-7xl grid-cols-1 gap-8 px-4 sm:grid-cols-2"
    >
      {
        trustItems.map(item => (
          <MagicCard title={item.title} icon={item.icon}>
            <p set:html={item.text} />
          </MagicCard>
        ))
      }
    </div>
  </Section>

  <Section
    id="technologien"
    className="bg-[radial-gradient(circle_at_70%_40%,var(--color-primary)_-200%,transparent_25%)]"
  >
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:layers-outline" text="Tech Stack" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Technologien, auf die Sie sich <br /><span class="text-primary">verlassen</span> können
      </h2>
    </div>

    <div
      class="reveal-fx--translate-up reveal-fx relative z-10 mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 px-4 sm:grid-cols-2"
    >
      {
        techCategories.map(cat => (
          <MagicCard title={cat.label} className="hover:translate-y-0">
            <div class="flex flex-wrap gap-2 pt-2">
              {cat.items.map(item => (
                <span class="badge badge-outline border-primary/30 bg-primary/5 px-3 py-2.5 text-sm">
                  {item}
                </span>
              ))}
            </div>
          </MagicCard>
        ))
      }
    </div>
  </Section>

  <Section
    id="portfolio"
    className="bg-[radial-gradient(circle_at_30%_50%,var(--color-primary)_-200%,transparent_35%),radial-gradient(circle_at_70%_60%,var(--color-accent)_-200%,transparent_25%)]"
  >
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:briefcase-outline" text="Portfolio" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Ausgewählte <span class="text-primary">Projekte</span>
      </h2>
      <p class="mx-auto max-w-4xl">
        Eine Auswahl abgeschlossener Arbeiten – von WordPress-Themes über Joomla-Templates bis zu
        kompletten Astro-Websites.
      </p>
    </div>

    <div class="reveal-fx--translate-up reveal-fx relative z-10 mx-auto mt-24 max-w-7xl px-4">
      <div class="projects grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {allProjects.map(project => <Project project={project} />)}
      </div>
    </div>
    <nav class="reveal-fx--translate-up reveal-fx flex justify-center px-4 pt-16">
      <Button className="ajax-load-more" href="#"
        >Mehr Projekte
        <Icon name="mdi:arrow-bottom" class="w-5 h-5" />
      </Button>
    </nav>
  </Section>

  <Section
    id="fragen"
    className="bg-[radial-gradient(circle_at_30%_50%,var(--color-primary)_-200%,transparent_25%),radial-gradient(circle_at_70%_60%,var(--color-accent)_-200%,transparent_20%)]"
  >
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:chat-question-outline" text="Gut zu wissen" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Sie haben noch <span class="text-primary">Fragen?</span>
      </h2>
      <p class="mx-auto max-w-4xl">
        Hier beantworte ich typische Fragen zu Zusammenarbeit, Technologien, Ablauf und Support.
      </p>
    </div>
    <div class="relative z-10 mx-auto mt-24 max-w-7xl grid-cols-3 px-4">
      <Faq />
    </div>
  </Section>

  <Section id="kontakt">
    <div
      class="reveal-fx--translate-up reveal-fx prose mx-auto max-w-7xl px-4 text-center lg:prose-lg prose-h2:mt-0"
    >
      <EyebrowHeading icon="mdi:message-outline" text="Kontakt" />
      <h2 class="text-3xl font-bold md:text-3xl lg:text-5xl">
        Lassen Sie uns über Ihr <br /><span class="text-primary">nächstes Projekt</span> sprechen
      </h2>
      <p class="mx-auto max-w-4xl">
        Neues Webprojekt oder Unterstützung bei einem bestehenden? Schreiben Sie mir, was Sie
        brauchen und welchen Tech-Stack Sie im Blick haben. ich melde mich mit einer Einschätzung.
        Unverbindlich und kostenlos.
      </p>
    </div>
    <div
      class="reveal-fx--translate-up reveal-fx relative z-10 mx-auto mb-6 mt-24 grid max-w-7xl grid-cols-1 place-items-center gap-8 px-4 lg:grid-cols-2"
    >
      <div>
        <ul>
          <ContactItem
            icon="mdi:map-outline"
            title="Adresse"
            text="Heinrich-Heine-Straße 34, 04600 Altenburg"
          />
          <ContactItem
            icon="mdi:email-outline"
            title="E-Mail"
            isMail={true}
            text="schoeneburg.j@googlemail.com"
          />

          <ContactItem
            icon="mdi:phone-outline"
            title="Telefon"
            text="03447-487890"
            isPhone={true}
          />
        </ul>
      </div>

      <Card
        className="w-full p-4 bg-linear-to-br from-primary/10 from-0% via-base-100 via-50% to-primary/10 to-100% transition-shadow hover:translate-y-0"
      >
        <form id="kontakt-form" class="mb-8 space-y-8" method="post" action="/api/contact">
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" />
          <input type="hidden" name="betreff" value="Agentur-Kooperation" />

          <div
            data-form-status
            role="status"
            aria-live="polite"
            class:list={[
              'hidden',
              'mb-8',
              formStatus === 'success' && 'alert alert-success',
              formStatus === 'error' && 'alert alert-error',
            ]}
          >
            {formStatus === 'success' && 'Vielen Dank! Ihre Nachricht wurde erfolgreich versendet.'}
            {
              formStatus === 'error' &&
                'Der Versand ist fehlgeschlagen. Bitte versuchen Sie es erneut.'
            }
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <label class="form-control w-full gap-3" for="agentur">
              <span class="label-text">Agenturname *</span>
              <input
                type="text"
                name="agentur"
                id="agentur"
                class="input"
                placeholder="Name Ihrer Agentur"
                required
              />
            </label>
            <label class="form-control w-full gap-3" for="name">
              <span class="label-text">Ansprechpartner *</span>
              <input
                type="text"
                name="name"
                id="name"
                class="input"
                placeholder="Ihr Name"
                required
              />
            </label>
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <label class="form-control w-full gap-3" for="email">
              <span class="label-text">E-Mail Adresse *</span>
              <input
                type="email"
                name="email"
                id="email"
                class="input"
                placeholder="Ihre E-Mail Adresse"
                required
              />
            </label>
            <label class="form-control w-full gap-3" for="telefon">
              <span class="label-text">Telefonnummer</span>
              <input
                type="text"
                name="telefon"
                id="telefon"
                class="input"
                placeholder="Ihre Telefonnummer"
              />
            </label>
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <label class="form-control w-full gap-3" for="techstack">
              <span class="label-text">Gewünschter Tech-Stack</span>
              <select name="techstack" id="techstack" class="select w-full">
                <option value="" disabled selected>Bitte wählen</option>
                <option value="WordPress">WordPress</option>
                <option value="Joomla">Joomla</option>
                <option value="Astro">Astro (Statische Website)</option>
                <option value="Noch unklar">Noch unklar / Beratung gewünscht</option>
              </select>
            </label>
            <label class="form-control w-full gap-3" for="zeitrahmen">
              <span class="label-text">Zeitrahmen</span>
              <select name="zeitrahmen" id="zeitrahmen" class="select w-full">
                <option value="" disabled selected>Bitte wählen</option>
                <option value="Sofort">Sofort</option>
                <option value="In 2-4 Wochen">In 2–4 Wochen</option>
                <option value="In 1-3 Monaten">In 1–3 Monaten</option>
                <option value="Noch offen">Noch offen</option>
              </select>
            </label>
          </div>

          <label class="form-control w-full gap-3" for="anliegen">
            <span class="label-text">Projektbeschreibung *</span>
            <textarea
              class="textarea w-full"
              name="anliegen"
              id="anliegen"
              placeholder="Beschreiben Sie kurz Ihr Projekt: Was soll umgesetzt werden? Gibt es bereits ein Design?"
              required></textarea>
          </label>

          <div class="form-control">
            <label class="label cursor-pointer justify-start gap-3" for="datenschutz">
              <input
                type="checkbox"
                class="checkbox"
                name="datenschutz"
                id="datenschutz"
                required
              />
              <span class="label-text">
                Ich habe die Datenschutzerklärung gelesen und stimme ihr zu.
              </span>
            </label>
          </div>

          <div
            class="group inline-block w-full transform cursor-pointer rounded-btn bg-primary p-[0.05rem] transition-transform duration-200 will-change-transform hover:shadow-md active:translate-y-[0.5px]"
          >
            <button
              type="submit"
              class="btn btn-primary w-[inherit] px-12 text-base font-normal shadow-sm"
            >
              <span
                data-submit-label
                data-default-text="Unverbindlich anfragen"
                data-loading-text="Wird gesendet..."
              >
                Unverbindlich anfragen
              </span>
              <Icon
                name="mdi:arrow-right"
                data-submit-icon
                class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-200 will-change-transform"
              />
              <Icon name="mdi:loading" data-submit-spinner class="hidden w-5 h-5 animate-spin" />
            </button>
          </div>
        </form>

        <span class="badge h-8 gap-2 self-end border-2 border-white/5">
          <Icon name="mdi:info" />
          Felder mit * müssen ausgefüllt werden!</span
        >
      </Card>
    </div>
  </Section>
</PageLayout>
