---
import { Icon } from 'astro-icon/components';
import { SITE } from '../config';
import Layout from '@layouts/BaseLayout.astro';
import Button from '@components/Ui/Button.astro';

interface Props {
  meta?: import('../types').MetaSEO;
  bodyClass?: string;
}

const { meta, bodyClass } = Astro.props;
const { footerLinks } = SITE;
---

<Layout {meta} bodyClass={bodyClass}>
  <div class="bg-base-100 relative circuit-pattern">
    <div
      class="absolute inset-0 bg-linear-to-b from-base-100 from-0% via-primary/15 via-40% to-base-100 to-90%"
    >
    </div>
    <header class="fixed top-0 z-20 w-full border-b border-white/5 bg-base-100/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:h-20">
        <a class="flex items-center gap-2 text-xl font-bold" href="/">
          <Icon name="mdi:code-braces-box" class="w-6 h-6 text-primary opacity-80" />
          <span
            class="bg-linear-to-r from-primary to-accent/80 bg-clip-text text-transparent text-shadow-md"
          >
            jswebForge
          </span>
        </a>
        <Button href="#kontakt-agentur" variant="outline">
          <Icon name="mdi:message-outline" class="w-5 h-5" /> Jetzt anfragen
        </Button>
      </div>
    </header>

    <div class="pt-16 lg:pt-20">
      <slot name="hero" />
    </div>
  </div>

  <main class="main-content grow" id="main-content">
    <slot />
  </main>

  <footer class="border-t border-white/5 bg-base-200/60">
    <div
      class="mx-auto flex max-w-7xl flex-col items-center gap-4 p-6 text-sm sm:flex-row sm:justify-between"
    >
      <p class="text-base-content/60">
        &copy; {new Date().getFullYear()} jswebForge &middot; Jörg Schöneburg
      </p>
      <nav class="flex gap-6">
        {
          footerLinks.map(item => (
            <a class="link-hover link text-sm text-base-content/60" href={item.href}>
              {item.name}
            </a>
          ))
        }
      </nav>
    </div>
  </footer>
</Layout>
