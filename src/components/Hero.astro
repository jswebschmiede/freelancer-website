---
import Button from '@components/Ui/Button.astro';
import { Icon } from 'astro-icon/components';
import EyebrowHeading from './Ui/EyebrowHeading.astro';
---

<div class="hero h-full px-4 pb-24 pt-16 sm:px-8 lg:pt-32">
  <div class="hero-content relative z-10 p-0 text-center">
    <div class="max-w-5xl mx-auto">
      <EyebrowHeading
        icon="mdi:handshake-outline"
        text="Ihr technischer Partner"
        className="js-fade-on-ready opacity-0 transition-all duration-700 translate-y-2"
      />
      <h1
        class="js-fade-on-ready translate-y-2 text-[clamp(1.75rem,-0.3765rem+7.2289vw,4.25rem)] font-bold leading-tight opacity-0 transition-all duration-700"
      >
        Pixelgenaue Umsetzung - <span
          class="bg-linear-to-l from-primary from-20% to-accent bg-clip-text text-transparent"
        >
          vom Design zur fertigen Website
        </span>
      </h1>
      <p
        class="js-fade-on-ready mx-auto max-w-4xl translate-y-2 pb-12 pt-6 text-[clamp(1rem,0.8319rem+0.7470vw,1.5rem)] opacity-0 transition-all duration-700"
      >
        Sie liefern das Design als Figma- oder Adobe-XD-Datei, ich übernehme die Umsetzung:
        WordPress-Themes, Joomla-Templates oder statische Websites mit Astro. Auf Wunsch arbeite ich
        White-Label direkt in Ihrem Team.
      </p>

      <div
        class="js-fade-on-ready flex translate-y-2 flex-col items-center justify-center gap-8 opacity-0 transition-all duration-700 sm:flex-row"
      >
        <Button href="#prozess" variant="outline">
          <Icon name="mdi:workflow-outline" class="w-5 h-5" /> Zum Projektablauf
        </Button>
        <Button href="#leistungen" className="group">
          Meine Leistungen <Icon
            name="mdi:arrow-right"
            class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-200 will-change-transform"
          />
        </Button>
      </div>

      <div
        class="js-fade-on-ready mt-12 opacity-0 translate-y-2 transition-all duration-700 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-base-content/60"
      >
        <span class="flex items-center gap-2">
          <Icon name="mdi:check-circle" class="w-4 h-4 text-primary" /> 100% White-Label
        </span>
        <span class="flex items-center gap-2">
          <Icon name="mdi:check-circle" class="w-4 h-4 text-primary" /> Pixelgenau
        </span>
        <span class="flex items-center gap-2">
          <Icon name="mdi:check-circle" class="w-4 h-4 text-primary" /> Festpreise möglich
        </span>
      </div>
    </div>
  </div>
</div>
